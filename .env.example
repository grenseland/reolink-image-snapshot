REOLINK_HOST=192.168.1.100
REOLINK_USERNAME=admin
REOLINK_PASSWORD=your_password_here
REOLINK_PORT=443
REOLINK_CHANNEL=0
REOLINK_INTERVAL=120
REOLINK_STREAM=main
REOLINK_BATTERY_MAH=5000
REOLINK_TIMEOUT=120
REOLINK_RETRIES=2
# Organise snapshots into yyyy/mm/dd/ subdirectories (recommended for long-running setups)
# REOLINK_SUBDIR_BY_DATE=true
# Use local system time in filenames instead of UTC (default: UTC with -utc suffix)
# Also set TZ= to the correct timezone, e.g. TZ=Europe/Oslo
# REOLINK_LOCAL_TIME=true
# Docker: mount a host folder to /data (see README)
SNAPSHOT_OUTPUT_DIR=/data

# Display — default is plain line logging. Set to true to enable full-screen UI.
# REOLINK_UI=true

# Optional tab-separated battery log
# REOLINK_BATTERY_LOG=/data/battery.tsv

# Write status.json to a local directory (e.g. same as snapshot dir)
# REOLINK_STATUS_DIR=/data

# S3 upload (credentials via standard AWS env vars below)
# REOLINK_S3_BUCKET=my-bucket
# REOLINK_S3_PREFIX=reolink/tak          # global fallback prefix for all upload types
# REOLINK_S3_SNAPSHOT_PREFIX=            # overrides prefix for snapshots only
# REOLINK_S3_STATUS_PREFIX=              # overrides prefix for status.json only
# REOLINK_S3_REGION=eu-north-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Disable latest.jpg upload (enabled by default when bucket is set):
# REOLINK_S3_NO_LATEST=true
# Also upload with the timestamped filename (disabled by default):
# REOLINK_S3_TIMESTAMPED=true
# Disable status.json upload (enabled by default when bucket is set):
# REOLINK_S3_NO_STATUS=true

# Timelapse video generation (requires ffmpeg on PATH)
#
# Option A — single timelapse shorthand:
# REOLINK_TIMELAPSE_WINDOW=today          # today | 2d | 3d | 1w | daily-at=HH:MM
# REOLINK_TIMELAPSE_SCHEDULE=daily=23:00  # hourly | every=Nm | every=Nh | daily=HH:MM
# REOLINK_TIMELAPSE_OUTPUT=/data/timelapses
# REOLINK_TIMELAPSE_NAME=                 # leave blank for auto-naming
# REOLINK_TIMELAPSE_FRAMERATE=24
#
# Option B — multiple timelapses (same key=value format as --timelapse flag):
# REOLINK_TIMELAPSE_1=window=today,schedule=daily=23:00,output=/data/tl,s3prefix=tl/daily
# REOLINK_TIMELAPSE_2=window=1w,schedule=daily=00:00,output=/data/tl,s3prefix=tl/weekly
# REOLINK_TIMELAPSE_3=window=daily-at=12:00,schedule=hourly,name=noon.mp4
# (Scanned 1–20; stops at first missing number. Option A and B can be combined.)

# One-shot / restart
# REOLINK_ONCE=true
# REOLINK_RESTART_LOOP=true
# REOLINK_RESTART_DELAY=30
